# Paste your OpenAI API key here for Whisper transcription
OPENAI_API_KEY=

# Paste your Gemini API key here for Gemini transcription
GEMINI_API_KEY=

# Optional: path to a Netscape-format cookies file for private reels
# Export cookies from your browser using a "Get cookies.txt LOCALLY" extension
COOKIES_FILE=

# Optional: load cookies directly from browser ("chrome", "firefox", "safari")
COOKIES_FROM_BROWSER=
